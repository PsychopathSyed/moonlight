# ============================================
# Event Rental Management System - Environment Configuration
# ============================================

# ============================================
# Application Settings
# ============================================

ENVIRONMENT=production

# Server Settings
HOST=0.0.0.0
PORT=8000

# ============================================
# Database Settings
# ============================================

# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://hadit7182:CHANGE_PASSWORD@localhost:5432/event_rental

# Database Connection Pool Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# Security Settings
# ============================================

# JWT Secret Key (CHANGE THIS IN PRODUCTION!)
# Generate a secure random key using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-char

# JWT Algorithm
ALGORITHM=HS256

# Token Expiration Times
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# CORS Settings
# ============================================

# Allowed origins for API access (comma-separated)
CORS_ORIGINS=["http://haditex.net","http://localhost:5173","http://localhost:3000"]

# ============================================
# Email Settings (Optional)
# ============================================

# SMTP Configuration for sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Default sender email
EMAIL_FROM=noreply@haditex.net

# ============================================
# File Upload Settings
# ============================================

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=10

# Upload directory
UPLOAD_DIR=./uploads

# ============================================
# Backup Settings
# ============================================

# Backup directory
BACKUP_DIR=./backups

# Backup retention period in days
BACKUP_RETENTION_DAYS=30

# ============================================
# Rate Limiting Settings
# ============================================

# Requests per minute per user
RATE_LIMIT_PER_MINUTE=100

# Requests per minute per IP address
RATE_LIMIT_PER_MINUTE_IP=1000

# ============================================
# Logging Settings
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

# ============================================
# Additional Settings
# ============================================

# Default currency code
DEFAULT_CURRENCY=PKR

# Default tax rate percentage
DEFAULT_TAX_RATE=17

# Default company name
DEFAULT_COMPANY_NAME=Event Rental Co

# Notification settings
# Enable email notifications
EMAIL_NOTIFICATIONS_ENABLED=false

# Enable SMS notifications (requires SMS provider setup)
SMS_NOTIFICATIONS_ENABLED=false

# Payment gateway settings (if using payment gateway)
PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_API_KEY=
PAYMENT_GATEWAY_SECRET_KEY=
